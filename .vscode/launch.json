	"version": "0.2.0",
	"configurations": [

		{
			"name": "Python Debugger: Current File",
			"type": "debugpy",
			"request": "launch",
			"program": "${file}",
			"console": "integratedTerminal"
		},
		{
			"name": "Python: Convert ChatGPT to Obsidian Copilot",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/convert_chatgpt_to_obsidian_copilot.py",
			"console": "integratedTerminal",
			"args": ["--html", "chatgpt-data-test/chat.html"],
		}
	]
}